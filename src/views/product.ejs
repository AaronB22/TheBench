<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/products.css">
  <link rel="icon" href="/images/Icon.png">
  <script src="/js/products.js" defer></script>
  <title>The Bench</title>
</head>
<body>
  <%- include('partials/header') %>
  <section id="productSection">
    <section id="filterSection">
      <h2>Filters</h2>
      <div id="priceContext">
        <label id="priceLabel">Price</label>
        <div id="priceRange">
          <input id='minPrice'type="number" min="0" placeholder="Min Price">
          <div id="priceDash"> to </div>
          <input id="maxPrice" type="number"  min="0" placeholder="Max Price">
        </div>
      </div>
      <button id="filterBtn"> Apply Filters</button>
      <form id="categoryContext">
        <label for="football">
          <input type="radio" id="football" name="category"></input>
          Football
        </label>
        <label for="basketball">
          <input type="radio" id="basketball" name="category"></input>
          Basketball
        </label>
        <label for="baseball">
          <input type="radio" id="baseball" name="category"></input>
          Baseball
        </label>
        <label for="hockey">
          <input type="radio" id="hockey" name="category"></input>
          Hockey
        </label>
        <label for="soccer">
          <input type="radio" id="soccer" name="category"></input>
          Soccer
        </label>
      </form>
    
    </section>
    <section id="items">
      
    </section>

  </section>
</body>



</html>